    {
      "name": "04_Boundary_Reliability",
      "item": [
        {
          "name": "POST boundary temperature 80 is accepted with warning",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
